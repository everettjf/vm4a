{
  "name": "vm4a",
  "version": "2.6.0",
  "description": "JavaScript/TypeScript client for vm4a's HTTP API — Apple Silicon VMs as agent sandboxes.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "vm4a",
    "ai-agent",
    "vm",
    "macos",
    "apple-silicon",
    "sandbox"
  ],
  "license": "MIT",
  "homepage": "https://github.com/everettjf/vm4a",
  "repository": {
    "type": "git",
    "url": "https://github.com/everettjf/vm4a.git"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
